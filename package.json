{
  "name": "Portfolio",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "dev:prod": "ng serve --configuration production -o",
    "build": "ng build --configuration=production --base-href=https://raveniis.github.io/Portfolio/",
    "update:pages": "npm run build && npx angular-cli-ghpages --dir=dist/Portfolio/browser --branch=gh-pages",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 160,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/cdk": "~21.1.5",
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/forms": "^21.2.10",
    "@angular/material": "~21.1.5",
    "@angular/platform-browser": "^21.2.10",
    "@angular/router": "^21.2.10",
    "ng-recaptcha-2": "^21.0.1",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.22",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.10",
    "@angular/material": "^21.1.5",
    "@tailwindcss/postcss": "^4.1.12",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5"
  }
}
